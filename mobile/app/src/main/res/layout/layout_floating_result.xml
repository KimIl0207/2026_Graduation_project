<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp"
    android:elevation="15dp">

    <TextView
        android:id="@+id/tvResultTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📝 판독 결과"
        android:textColor="#6A65FF"
        android:textSize="19sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/ivCapturedImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:maxHeight="200dp"
        android:background="#F0F0F0"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="250dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp">
        <TextView
            android:id="@+id/tvResultContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="16sp"
            android:lineSpacingExtra="5dp"/>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutAiProbability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#F2F4F7"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvAiProbability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI가 생성했을 확률: 0%"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCloseResult"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="확인 (닫기)"
        android:backgroundTint="#6A65FF"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>